{
  "name": "pi-http-sniff",
  "version": "0.1.0",
  "author": {
    "name": "Jaylen Douglas",
    "email": "hello@jaylendouglas.com",
    "url": "https://jaylendouglas.com"
  },
  "description": "A Pi Coding Agent extension that logs HTTP traffic to and from LLM providers.",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ableinc/pi-http-sniff.git"
  },
  "homepage": "https://github.com/ableinc/pi-http-sniff#readme",
  "bugs": {
    "url": "https://github.com/ableinc/pi-http-sniff/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsc",
    "prepublishOnly": "pnpm build",
    "start": "node dist/index.js",
    "lint": "biome check",
    "format": "biome format",
    "fix": "biome check --fix"
  },
  "keywords": ["pi-package", "pi", "pi-coding-agent", "http", "sniffer", "proxy", "typescript", "http-request", "http-response"],
  "pi": {
    "extensions": ["./dist/index.js"]
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.8.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@earendil-works/pi-coding-agent": "^0.79.9",
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
